# ==========================================
# 🛑 Python 缓存与虚拟环境
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# ==========================================
# 🛑 保持空目录结构骨架 (忽略内容，但保留 .gitkeep)
# ==========================================
# 1. 数据集目录
datasets/archive/test/*
!datasets/archive/test/.gitkeep

datasets/archive/train/*
!datasets/archive/train/.gitkeep

# 2. 模型存放目录
models/*
!models/.gitkeep

# 3. 动态生成的音频缓存
audio/chat_rep/*
!audio/chat_rep/.gitkeep

# 4. LLM 聊天记忆缓存
llm/chat_data/*
!llm/chat_data/.gitkeep

# ==========================================
# 🛑 过程产物目录 (不保留骨架)
# ==========================================
# 进度记录目录
Progress/
# 训练生成的曲线图和日志
train_data/

# ==========================================
# 🛑 大型框架源码 (用户自行下载，无需保留骨架)
# ==========================================
GPT-SoVITS/

# ==========================================
# 🛑 敏感配置文件 (API Key, 本地路径等)
# ==========================================
audio/config.json
llm/config.json

# =========================================
# 🛑 其他文件
# =========================================
README_FOR_LLM.md
apply_license.py
data_possess.py
all_code.py
Learning/
chengqianyu_test.wav
datasets/count_images.py